{
  "installCommand": "npm install --omit=dev --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/power-list-daily",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/social-research-daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/contact-intelligence-worker",
      "schedule": "10 8 * * *"
    }
  ]
}
