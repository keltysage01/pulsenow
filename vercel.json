{
  "installCommand": "npm install --omit=dev --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/cron/social-research-daily.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/power-list-daily",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/social-research-daily",
      "schedule": "0 8 * * *"
    }
  ]
}
